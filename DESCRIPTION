Package: schemate
Title: Schema Inference, Editing, and Validation with 'checkmate'
Version: 0.1.1.9000
Authors@R: c(
    person(
        given = "Hongyuan",
        family = "Jia",
        role = c("aut", "cre", "cph"),
        email = "hongyuanjia@cqust.edu.cn",
        comment = c(ORCID = "0000-0002-0075-8183")
